\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Multiple temporal dimensions in activation space. Left: Points colored by categorical time scale (weeks/months/years/decades) reveal discrete clusters in the 2D attention space. Right: Binary choice (short-term vs long-term) is linearly separable, appearing as a threshold on the continuous magnitude dimension.}}{8}{figure.caption.19}\protected@file@percent }
\newlabel{fig:temporal_encoding}{{7}{8}{Multiple temporal dimensions in activation space. Left: Points colored by categorical time scale (weeks/months/years/decades) reveal discrete clusters in the 2D attention space. Right: Binary choice (short-term vs long-term) is linearly separable, appearing as a threshold on the continuous magnitude dimension}{figure.caption.19}{}}

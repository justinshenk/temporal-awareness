\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Attribution analysis results. Left: Scatter plot showing noising vs denoising agreement, colored by component type. Attention (blue) shows systematic inflation by denoising; MLPs (orange) cluster near the diagonal. Right: Top-scoring components by denoising, confirming L24 attention and L35 MLP as critical.}}{7}{figure.caption.17}\protected@file@percent }
\newlabel{fig:attribution}{{5}{7}{Attribution analysis results. Left: Scatter plot showing noising vs denoising agreement, colored by component type. Attention (blue) shows systematic inflation by denoising; MLPs (orange) cluster near the diagonal. Right: Top-scoring components by denoising, confirming L24 attention and L35 MLP as critical}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Scree plot comparison across components. The temporal encoding is not rank-1: multiple principal components capture meaningful variance, indicating a multi-dimensional representation.}}{7}{figure.caption.18}\protected@file@percent }
\newlabel{fig:scree}{{6}{7}{Scree plot comparison across components. The temporal encoding is not rank-1: multiple principal components capture meaningful variance, indicating a multi-dimensional representation}{figure.caption.18}{}}
